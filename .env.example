# Cloudflare Worker Secrets
# Set these via: wrangler secret put <KEY_NAME>

# Gemini API key - primary AI provider (gemini-2.5-flash)
# GEMINI_API_KEY=your_gemini_api_key

# Zhipu BigModel API key - fallback AI provider (glm-4-flash)
# Format: id.secret
# ZHIPU_API_KEY=your_zhipu_api_key

# Calendarific API key (optional) - provides additional holiday data
# CALENDARIFIC_API_KEY=your_calendarific_api_key
